APP_NAME=DistriCare
APP_ENV=development

# Desarrollo local. Cambia estos valores en tu archivo .env real.
DATABASE_URL=postgresql+psycopg://usuario:password@localhost:15432/districare
RABBITMQ_URL=amqp://usuario:password@localhost:5673/
RABBITMQ_EXCHANGE=districare.events
HEARTBEAT_TIMEOUT_SECONDS=15

# Origenes permitidos separados por coma.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cambia esta clave en tu .env y en los servicios desplegados.
API_KEY=change-me
ENABLE_API_DOCS=true

{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' http://localhost:5173 https://districare.vercel.app;"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM http://localhost:5173"
        }
      ]
    }
  ]
}
